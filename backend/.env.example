# Twilio OTP Configuration
# Sign up at https://www.twilio.com/try-twilio, get Account SID/Auth Token from Console dashboard
# Create Verify Service: Console > Verify > Services > Create new service (Messaging channel enabled)
# Add your credentials below, rename to .env (never commit .env!)

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid_here

# Server
PORT=5000

